{
  "ignorePatterns": [
    { "pattern": "^https://internal\\.example\\.com" }
  ],
  "replacementPatterns": [
    { "pattern": "^/", "replacement": "{{BASEURL}}/" }
  ],
  "httpHeaders": [
    { "urls": ["https://api.github.com"], "headers": { "Authorization": "token {{env.GITHUB_TOKEN}}" } }
  ],
  "aliveStatusCodes": [200, 206],
  "timeout": "5s",
  "retryOn429": true,
  "retryCount": 2
}
